{
  "version": 1,
  "description": "dotnet-artisan: smart defaults for .NET development",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/session-start-context.js\"",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/scripts/hooks/user-prompt-dotnet-reminder.js\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
